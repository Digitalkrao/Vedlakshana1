{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A Gaushala product like A2 Ghee, soaps, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Recipes and health tips",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string", "format": "uri" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "date"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog of Gaushala products"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchase transaction records"
    },
    "/blog/{postId}": {
      "schema": "BlogPost",
      "description": "Articles, recipes, and health tips"
    }
  }
}
